# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=your-openrouter-api-key
MODEL=anthropic/claude-3-haiku

# --- RevenueHero booking ---
# The chat feeds its own qualification form to the RevenueHero JavaScript SDK
# (the "Inside your application" install method). ROUTER_ID is the active config.
NEXT_PUBLIC_RH_ROUTER_ID=5050
# Legacy: the hosted "Inbound router link URL". No longer used by the SDK flow,
# kept only for reference.
NEXT_PUBLIC_RH_BOOKING_URL=https://aiaccountant.schedulehero.io/inbound/vouchrit-vs-aia-webflow-router
# Set to "true" to show the in-chat "Book a Demo" button.
NEXT_PUBLIC_ENABLE_BOOK_A_DEMO=false

# --- Supabase (Website Bot project) — server-side prompt logging ---
SUPABASE_URL=https://mjgullrwpdtnhyrwzevn.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
